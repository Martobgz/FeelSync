const int BPM_COUNT = 2016;

BLECharacteristic* rxChar;      // phone -> ESP32 (WRITE)
BLECharacteristic* hrChar;      // ESP32 -> phone (NOTIFY)

bool     deviceConnected = false;
int      bpmIndex        = 0;
unsigned long lastSend   = 0;
unsigned long motorEnd   = 0;

// ─── BLE server callbacks ──────────────────────────────────────────────────────
class ServerCallbacks : public BLEServerCallbacks {
  void onConnect(BLEServer*) override {
    deviceConnected = true;
    Serial.println("[BLE] Phone connected");
  }
  void onDisconnect(BLEServer*) override {
    deviceConnected = false;
    Serial.println("[BLE] Phone disconnected, restarting advertising...");
    delay(500);
    BLEDevice::startAdvertising();
  }
};

// ─── WRITE characteristic callback (VIBRATE) ──────────────────────────────────
class WriteCallbacks : public BLECharacteristicCallbacks {
  void onWrite(BLECharacteristic* pChar) override {
    String value = pChar->getValue();
    if (value == "VIBRATE") {
      digitalWrite(MOTOR_PIN, HIGH);
      motorEnd = millis() + 200;
      Serial.println("[Motor] ON");
    }
  }
};

// ─── setup ────────────────────────────────────────────────────────────────────
void setup() {
  Serial.begin(115200);
  pinMode(MOTOR_PIN, OUTPUT);
  digitalWrite(MOTOR_PIN, LOW);

  BLEDevice::init("FeelSync");
  BLEServer* pServer = BLEDevice::createServer();
  pServer->setCallbacks(new ServerCallbacks());

  // Custom FeelSync service (VIBRATE)
  BLEService* feelSyncSvc = pServer->createService(FEELSYNC_SERVICE_UUID);
  rxChar = feelSyncSvc->createCharacteristic(FEELSYNC_RX_UUID,
             BLECharacteristic::PROPERTY_WRITE);
  rxChar->setCallbacks(new WriteCallbacks());
  feelSyncSvc->start();

  // Standard GATT Heart Rate service
  BLEService* hrSvc = pServer->createService(HR_SERVICE_UUID);
  hrChar = hrSvc->createCharacteristic(HR_MEASUREMENT_UUID,
             BLECharacteristic::PROPERTY_NOTIFY |
             BLECharacteristic::PROPERTY_READ);
  hrChar->addDescriptor(new BLE2902());  // CCCD — required for NOTIFY
  hrSvc->start();

  BLEAdvertising* pAdv = BLEDevice::getAdvertising();
  pAdv->addServiceUUID(HR_SERVICE_UUID);
  pAdv->setScanResponse(true);
  pAdv->start();

  Serial.printf("FeelSync mock sender ready. %d BPM entries, interval=%lums",BPM_COUNT, SEND_INTERVAL_MS);
}

// ─── loop ─────────────────────────────────────────────────────────────────────
void loop() {
  // Send next BPM reading
  if (deviceConnected && millis() - lastSend >= SEND_INTERVAL_MS) {
    uint8_t bpm = pgm_read_byte(&BPM_DATA[bpmIndex]);
    // Standard GATT HR Measurement packet (2 bytes):
    //   byte[0] = 0x00 → flags: uint8 format, no contact info, no energy, no RR
    //   byte[1] = BPM value
    uint8_t packet[2] = { 0x00, bpm };
    hrChar->setValue(packet, 2);
    hrChar->notify();
    Serial.printf("[%d/%d] BPM: %d", bpmIndex + 1, BPM_COUNT, bpm);
    bpmIndex = (bpmIndex + 1) % BPM_COUNT;
    lastSend = millis();
  }

  // Non-blocking motor off
  if (motorEnd > 0 && millis() >= motorEnd) {
    digitalWrite(MOTOR_PIN, LOW);
    motorEnd = 0;
    Serial.println("[Motor] OFF");
  }
}